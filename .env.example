# App
SPRING_PROFILES_ACTIVE=dev
PORT=8080
JWT_SECRET=your-secret-key-must-be-at-least-256-bits

# Criptografia
# Gerar com: openssl rand -hex 32
CPF_ENCRYPTION_KEY=your-32-byte-hex-key-here

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/allset_dev
DB_USER=postgres
DB_PASS=postgres
POSTGRES_DB=allset_dev
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Jobs
# Cron de purga de contas expiradas (padrão: diariamente às 02h)
USER_PURGE_CRON=0 0 2 * * *

# Auth — TTLs
ACCESS_TOKEN_TTL_MINUTES=15   # Tempo de vida do access token (minutos)
REFRESH_TOKEN_TTL_DAYS=7      # Tempo de vida do refresh token (dias)
RESET_CODE_TTL_MINUTES=10     # Tempo de vida do código de reset de senha (minutos)

# Email / Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx          # API Key do Resend
EMAIL_FROM=AllSet <noreply@allset.com.br>  # Remetente (aceita formato "Nome <email>")

# CORS / Frontend
# Em produção, definir com o domínio exato do frontend (ex: https://app.allset.com.br)
# Nunca usar "*" em produção — permite que qualquer site abra conexões WebSocket em nome do usuário
FRONTEND_URL=*

# Chat
CHAT_MESSAGE_MAX_LENGTH=4000  # Tamanho máximo do conteúdo de mensagem (padrão: 4000)
CHAT_MESSAGE_PAGE_SIZE=50     # Tamanho da página no histórico de mensagens (padrão: 50)

# Seed de desenvolvimento
SEED_ENABLED=false            # Ative para popular dados de demonstração no startup

# Storage / MinIO (S3-compatível)
# Em dev tudo roda no docker-compose; em prod apontar para o cluster MinIO ou S3 real.
# MINIO_ENDPOINT é o endereço interno usado pelo backend; MINIO_PUBLIC_ENDPOINT é o
# endereço externo gravado nas URLs pré-assinadas devolvidas ao cliente.
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET_PREFIX=allset            # prefixo aplicado a todos os buckets (allset-avatars, allset-documents, ...)
MINIO_AUTO_CREATE_BUCKETS=true        # cria buckets faltantes no startup; desligar em prod se DevOps gerenciar
MINIO_PRESIGNED_URL_TTL_MINUTES=15    # TTL padrão da URL pré-assinada de download
MINIO_PRESIGNED_URL_TTL_LONG_HOURS=24 # TTL longo (export LGPD)

# Limites por tipo de upload (MB) — validados no servidor por bucket
MINIO_MAX_AVATAR_SIZE_MB=5
MINIO_MAX_DOCUMENT_SIZE_MB=5
MINIO_MAX_ORDER_PHOTO_SIZE_MB=5
MINIO_MAX_CHAT_ATTACHMENT_SIZE_MB=5
MINIO_MAX_CATALOG_ICON_SIZE_MB=1
MINIO_MAX_DISPUTE_EVIDENCE_SIZE_MB=5
MINIO_MAX_DATA_EXPORT_SIZE_MB=100

# Portas locais expostas pelo container MinIO (somente docker-compose)
MINIO_API_PORT=9000      # API S3
MINIO_CONSOLE_PORT=9001  # Console web (http://localhost:9001)

# Express (matchmaking de pedidos por proximidade)
EXPRESS_SEARCH_RADIUS_METERS=300       # Raio único de busca, em metros (padrão: 300)
EXPRESS_PROPOSAL_WINDOW_MINUTES=15     # Janela em que profissionais podem propor (padrão: 15)
EXPRESS_CLIENT_WINDOW_MINUTES=30       # Janela após propostas para o cliente escolher (padrão: 30)
EXPRESS_MAX_QUEUE_SIZE=10              # Máximo de profissionais notificados (padrão: 10)

# Geocoding (provider Nominatim / OpenStreetMap)
# Política do Nominatim exige User-Agent identificador com contato.
# Em produção, manter um valor único para o serviço (ex: "AllSet-API/1.0 (contato@allset.com.br)").
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=AllSet-API/1.0 (contato@allset.com.br)
GEOCODING_CACHE_TTL_SECONDS=2592000          # TTL do cache de resultados positivos (padrão: 30 dias)
GEOCODING_NEGATIVE_CACHE_TTL_SECONDS=300     # TTL do cache de "não localizado" (padrão: 5min)
GEOCODING_ENABLED=true                       # Kill-switch — false desabilita lookup e enriquecimento
