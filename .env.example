# App
SPRING_PROFILES_ACTIVE=dev
PORT=8080
JWT_SECRET=your-secret-key-must-be-at-least-256-bits

# Criptografia
# Gerar com: openssl rand -hex 32
CPF_ENCRYPTION_KEY=your-32-byte-hex-key-here

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/allset_dev
DB_USER=postgres
DB_PASS=postgres
POSTGRES_DB=allset_dev
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Jobs
# Cron de purga de contas expiradas (padrão: diariamente às 02h)
USER_PURGE_CRON=0 0 2 * * *

# Auth — TTLs
ACCESS_TOKEN_TTL_MINUTES=15   # Tempo de vida do access token (minutos)
REFRESH_TOKEN_TTL_DAYS=7      # Tempo de vida do refresh token (dias)
RESET_CODE_TTL_MINUTES=10     # Tempo de vida do código de reset de senha (minutos)

# Email / Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx          # API Key do Resend
EMAIL_FROM=AllSet <noreply@allset.com.br>  # Remetente (aceita formato "Nome <email>")
